<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="?attr/appBackground">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Stutter"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="@color/brand_blue"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Learn Informatics, Master Your Skills"
        android:textSize="14sp"
        android:textColor="?attr/appTextSecondary"
        android:layout_marginBottom="40dp"/>

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:paddingHorizontal="16dp"
        android:textColor="?attr/appTextPrimary"
        android:textColorHint="?attr/appTextHint"
        android:background="@drawable/input_rounded_white"
        android:layout_marginBottom="12dp"/>

    <!-- Only visible during registration -->
    <EditText
        android:id="@+id/etUsername"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Username"
        android:paddingHorizontal="16dp"
        android:textColor="?attr/appTextPrimary"
        android:textColorHint="?attr/appTextHint"
        android:background="@drawable/input_rounded_white"
        android:layout_marginBottom="12dp"
        android:visibility="gone"/>

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Password"
        android:inputType="textPassword"
        android:paddingHorizontal="16dp"
        android:textColor="?attr/appTextPrimary"
        android:textColorHint="?attr/appTextHint"
        android:background="@drawable/input_rounded_white"
        android:layout_marginBottom="12dp"/>

    <!-- Only visible during registration -->
    <EditText
        android:id="@+id/etConfirmPassword"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Confirm Password"
        android:inputType="textPassword"
        android:paddingHorizontal="16dp"
        android:textColor="?attr/appTextPrimary"
        android:textColorHint="?attr/appTextHint"
        android:background="@drawable/input_rounded_white"
        android:layout_marginBottom="20dp"
        android:visibility="gone"/>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:visibility="gone"
        android:layout_marginBottom="20dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAuth"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Login"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"
        app:backgroundTint="@color/brand_blue"
        app:cornerRadius="26dp"/>

    <TextView
        android:id="@+id/tvToggleMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Don't have an account? Register here"
        android:textColor="@color/brand_blue"
        android:textStyle="bold"
        android:textSize="13sp"/>

</LinearLayout>