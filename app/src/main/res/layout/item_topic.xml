<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/card_white"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvIcon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:gravity="center"
        android:text="📚"
        android:textSize="24sp"
        android:background="@drawable/icon_bg_blue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvLock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒"
        android:textSize="18sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvTopicTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Data Structures"
        android:textStyle="bold"
        android:textColor="#111827"
        android:textSize="16sp"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/tvIcon"
        app:layout_constraintTop_toTopOf="@id/tvIcon"
        app:layout_constraintEnd_toStartOf="@id/tvLock"/>

    <TextView
        android:id="@+id/tvTopicDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Arrays, Lists, Stacks , Queues"
        android:textColor="#6B7280"
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="@id/tvTopicTitle"
        app:layout_constraintTop_toBottomOf="@id/tvTopicTitle"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress"
        android:layout_width="0dp"
        android:layout_height="10dp"
        android:layout_marginTop="10dp"
        android:indeterminate="false"
        app:layout_constraintStart_toStartOf="@id/tvTopicTitle"
        app:layout_constraintTop_toBottomOf="@id/tvTopicDesc"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvLessons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="3/5 lessons completed"
        android:textColor="#6B7280"
        android:textSize="12sp"
        android:layout_marginTop="6dp"
        app:layout_constraintStart_toStartOf="@id/tvTopicTitle"
        app:layout_constraintTop_toBottomOf="@id/progress"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
