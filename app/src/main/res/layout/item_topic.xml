<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="?attr/appCard"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvIcon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:gravity="center"
        android:text="📚"
        android:textSize="24sp"
        android:background="@drawable/icon_bg_blue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvLock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒"
        android:textSize="18sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvTopicTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Topic"
        android:textStyle="bold"
        android:textColor="?attr/appTextPrimary"
        android:textSize="16sp"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/tvIcon"
        app:layout_constraintTop_toTopOf="@id/tvIcon"
        app:layout_constraintEnd_toStartOf="@id/tvLock"/>

    <TextView
        android:id="@+id/tvTopicDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Description"
        android:textColor="?attr/appTextSecondary"
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="@id/tvTopicTitle"
        app:layout_constraintTop_toBottomOf="@id/tvTopicTitle"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:layout_marginTop="10dp"
        android:indeterminate="false"
        android:max="100"
        android:progress="0"
        app:layout_constraintStart_toStartOf="@id/tvTopicTitle"
        app:layout_constraintTop_toBottomOf="@id/tvTopicDesc"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvLessons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="0/10 levels completed"
        android:textColor="?attr/appTextSecondary"
        android:textSize="12sp"
        android:layout_marginTop="6dp"
        app:layout_constraintStart_toStartOf="@id/tvTopicTitle"
        app:layout_constraintTop_toBottomOf="@id/progress"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
