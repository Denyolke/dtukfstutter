<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/appBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:padding="16dp" android:background="?attr/appHeader" android:elevation="4dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Shop" android:textSize="22sp" android:textStyle="bold"
                android:textColor="?attr/appTextPrimary"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Spend your coins on power-ups" android:textSize="13sp"
                android:textColor="?attr/appTextSecondary" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/pill_yellow"
            android:paddingHorizontal="14dp" android:paddingVertical="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🪙 " android:textSize="16sp"/>
            <TextView android:id="@+id/tvShopCoins" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0" android:textSize="16sp"
                android:textStyle="bold" android:textColor="@color/accent_yellow_text"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Active booster banner -->
    <LinearLayout android:id="@+id/bannerActiveBooster"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center"
        android:background="@color/accent_green_bg"
        android:paddingVertical="10dp" android:paddingHorizontal="16dp" android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚡ " android:textSize="16sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="XP Doubler ACTIVE — next quiz gives 2× XP!"
            android:textSize="13sp" android:textStyle="bold" android:textColor="@color/accent_green_text"/>
    </LinearLayout>

    <ProgressBar android:id="@+id/pbShopLoading"
        android:layout_width="40dp" android:layout_height="40dp"
        android:layout_gravity="center_horizontal" android:layout_marginTop="32dp" android:visibility="visible"/>

    <ScrollView android:id="@+id/scrollShop"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:visibility="gone">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Power-Ups" android:textSize="14sp" android:textStyle="bold"
                android:textColor="?attr/appTextPrimary" android:layout_marginBottom="12dp"/>

            <!-- XP Doubler card -->
            <androidx.cardview.widget.CardView android:id="@+id/cardXpDoubler"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" android:elevation="2dp"
                app:cardCornerRadius="16dp" app:cardBackgroundColor="?attr/appCard">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">

                        <TextView android:layout_width="52dp" android:layout_height="52dp"
                            android:gravity="center" android:text="⚡" android:textSize="26sp"
                            android:background="@drawable/icon_bg_blue" android:layout_marginEnd="14dp"/>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="XP Doubler" android:textSize="17sp" android:textStyle="bold"
                                android:textColor="?attr/appTextPrimary"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Doubles XP earned on your next quiz" android:textSize="12sp"
                                android:textColor="?attr/appTextSecondary" android:layout_marginTop="2dp"/>
                            <TextView android:id="@+id/tvBoosterOwned"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Owned: 0" android:textSize="13sp"
                                android:textColor="@color/brand_blue" android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical" android:gravity="center"
                            android:background="@drawable/pill_yellow"
                            android:paddingHorizontal="10dp" android:paddingVertical="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🪙" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="100" android:textSize="13sp" android:textStyle="bold"
                                android:textColor="@color/accent_yellow_text"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBuyDoubler"
                            android:layout_width="0dp" android:layout_height="48dp"
                            android:layout_weight="1" android:layout_marginEnd="8dp"
                            android:text="Buy (🪙 100)" android:textColor="@android:color/white"
                            android:textStyle="bold"
                            app:backgroundTint="@color/brand_blue" app:cornerRadius="24dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnUseDoubler"
                            android:layout_width="0dp" android:layout_height="48dp"
                            android:layout_weight="1" android:text="Activate ⚡"
                            android:textColor="@android:color/white" android:textStyle="bold"
                            app:backgroundTint="@color/accent_green" app:cornerRadius="24dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Coming Soon" android:textSize="14sp" android:textStyle="bold"
                android:textColor="?attr/appTextHint" android:layout_marginTop="8dp" android:layout_marginBottom="12dp"/>

            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                android:elevation="1dp" android:alpha="0.5"
                app:cardCornerRadius="16dp" app:cardBackgroundColor="?attr/appSurfaceVariant">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">
                    <TextView android:layout_width="52dp" android:layout_height="52dp" android:gravity="center"
                        android:text="❤️" android:textSize="26sp" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Heart Refill" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="?attr/appTextHint"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Restore all hearts instantly" android:textSize="12sp"
                            android:textColor="?attr/appTextHint"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔒 Soon" android:textSize="13sp" android:textColor="?attr/appTextHint"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:elevation="1dp" android:alpha="0.5"
                app:cardCornerRadius="16dp" app:cardBackgroundColor="?attr/appSurfaceVariant">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">
                    <TextView android:layout_width="52dp" android:layout_height="52dp" android:gravity="center"
                        android:text="🛡️" android:textSize="26sp" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Streak Shield" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="?attr/appTextHint"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Protect your streak for one day" android:textSize="12sp"
                            android:textColor="?attr/appTextHint"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔒 Soon" android:textSize="13sp" android:textColor="?attr/appTextHint"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
