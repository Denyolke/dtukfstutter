<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_blue">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shop"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spend your coins on power-ups"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="24dp" />

        <!-- Coin balance card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:elevation="4dp"
            app:cardCornerRadius="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:background="@android:color/white">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🪙"
                    android:textSize="36sp"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your Balance"
                        android:textSize="12sp"
                        android:textColor="#6B7280" />

                    <TextView
                        android:id="@+id/tvCoins"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🪙 0 Coins"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#D97706" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Section title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Power-Ups"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:layout_marginBottom="12dp" />

        <!-- XP Doubler card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            app:cardCornerRadius="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@android:color/white">

                <!-- Top row: icon + name + count badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:text="⚡"
                        android:gravity="center"
                        android:textSize="28sp"
                        android:background="@drawable/icon_bg_blue"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="XP Doubler"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1F2937" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Doubles XP on your next quiz"
                            android:textSize="13sp"
                            android:textColor="#6B7280" />

                    </LinearLayout>

                    <!-- Owned count badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Owned"
                            android:textSize="11sp"
                            android:textColor="#6B7280" />

                        <TextView
                            android:id="@+id/tvBoosterCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="x0"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#2563EB" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Active status -->
                <TextView
                    android:id="@+id/tvBoosterStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inactive"
                    android:textSize="13sp"
                    android:textColor="#6B7280"
                    android:layout_marginBottom="16dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"
                    android:layout_marginBottom="16dp" />

                <!-- Buttons row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Buy button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBuyDoubler"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Buy — 🪙 100"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"
                        app:backgroundTint="#1d5dea"
                        app:cornerRadius="24dp" />

                    <!-- Activate button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnActivateDoubler"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Activate ⚡"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="#10B981"
                        app:cornerRadius="24dp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Coming soon card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="2dp"
            app:cardCornerRadius="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:background="@android:color/white"
                android:alpha="0.5">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="❤️"
                    android:gravity="center"
                    android:textSize="28sp"
                    android:background="@drawable/icon_bg_blue"
                    android:layout_marginEnd="14dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Heart Refill"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1F2937" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Coming soon"
                        android:textSize="13sp"
                        android:textColor="#6B7280" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textSize="22sp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
