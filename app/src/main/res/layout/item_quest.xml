<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:elevation="3dp"
    app:cardCornerRadius="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp"
        android:background="@android:color/white">

        <!-- Top row: title + reward -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvQuestTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Quest Title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1F2937" />

            <TextView
                android:id="@+id/tvQuestReward"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🪙 +30"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#D97706"
                android:background="@drawable/pill_yellow"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp" />

        </LinearLayout>

        <!-- Description -->
        <TextView
            android:id="@+id/tvQuestDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quest description"
            android:textSize="13sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="12dp" />

        <!-- Progress bar -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/questProgress"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:indeterminate="false"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="8dp"
            app:trackCornerRadius="4dp" />

        <!-- Bottom row: progress text + status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvQuestProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 / 3"
                android:textSize="12sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvQuestStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In Progress"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#6B7280" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
