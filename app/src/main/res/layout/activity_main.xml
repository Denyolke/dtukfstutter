<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackground">

    <FrameLayout
        android:id="@+id/container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="?attr/appNav"
        android:elevation="10dp"
        android:paddingHorizontal="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:id="@+id/btnLeaderboardContainer"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="6dp"
            android:background="@drawable/nav_item_inactive_bg" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/ivLeaderboard" android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_trophy" android:tint="@color/nav_inactive"
                android:contentDescription="Leaderboard" android:scaleType="fitCenter"/>
            <TextView android:id="@+id/tvLeaderboardLabel" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Ranks" android:textSize="10sp"
                android:textColor="@color/nav_inactive" android:textStyle="bold" android:layout_marginTop="3dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnShopContainer"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="6dp"
            android:background="@drawable/nav_item_inactive_bg" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/ivShop" android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_shop" android:tint="@color/nav_inactive"
                android:contentDescription="Shop" android:scaleType="fitCenter"/>
            <TextView android:id="@+id/tvShopLabel" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Shop" android:textSize="10sp"
                android:textColor="@color/nav_inactive" android:textStyle="bold" android:layout_marginTop="3dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnHomeContainer"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="6dp"
            android:background="@drawable/nav_item_active_bg" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/ivHome" android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_house" android:tint="@color/brand_blue"
                android:contentDescription="Home" android:scaleType="fitCenter"/>
            <TextView android:id="@+id/tvHomeLabel" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Home" android:textSize="10sp"
                android:textColor="@color/brand_blue" android:textStyle="bold" android:layout_marginTop="3dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnQuestsContainer"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="6dp"
            android:background="@drawable/nav_item_inactive_bg" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/ivQuests" android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_quests" android:tint="@color/nav_inactive"
                android:contentDescription="Quests" android:scaleType="fitCenter"/>
            <TextView android:id="@+id/tvQuestsLabel" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Quests" android:textSize="10sp"
                android:textColor="@color/nav_inactive" android:textStyle="bold" android:layout_marginTop="3dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnProfileContainer"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="6dp"
            android:background="@drawable/nav_item_inactive_bg" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/ivProfile" android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_user" android:tint="@color/nav_inactive"
                android:contentDescription="Profile" android:scaleType="fitCenter"/>
            <TextView android:id="@+id/tvProfileLabel" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Profile" android:textSize="10sp"
                android:textColor="@color/nav_inactive" android:textStyle="bold" android:layout_marginTop="3dp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
