<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Stutter" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Material required -->
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorPrimaryVariant">@color/brand_blue_dark</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/brand_blue</item>
        <item name="colorOnSecondary">@android:color/white</item>

        <!-- App surfaces -->
        <item name="appBackground">@color/light_background</item>
        <item name="appSurface">@color/light_surface</item>
        <item name="appSurfaceVariant">@color/light_surface_variant</item>
        <item name="appCard">@color/light_card</item>
        <item name="appNav">@color/light_nav</item>
        <item name="appHeader">@color/light_header</item>
        <item name="appDivider">@color/light_divider</item>

        <!-- Text -->
        <item name="appTextPrimary">@color/light_text_primary</item>
        <item name="appTextSecondary">@color/light_text_secondary</item>
        <item name="appTextHint">@color/light_text_hint</item>

        <!-- Switch tint -->
        <item name="colorControlActivated">@color/brand_blue</item>

    </style>

</resources>